{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "InstaDesk",
  "version": "0.1.0",
  "identifier": "com.fcxestudios.instadesk",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ui run dev",
    "beforeBuildCommand": "npm --prefix ui run build && node src-tauri/scripts/build-agent.mjs"
  },
  "app": {
    "windows": [
      {
        "title": "InstaDesk",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 680,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "binaries/InstaDesk.WinAgent.exe": "binaries/InstaDesk.WinAgent.exe",
      "../ui/public/manual/InstaDesk-Manual-EN.pdf": "manual/InstaDesk-Manual-EN.pdf",
      "../ui/public/manual/InstaDesk-Manual-ES.pdf": "manual/InstaDesk-Manual-ES.pdf"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
