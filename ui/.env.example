# InstaDesk telemetry keys (copy to `.env` — git-ignored — to activate).
# All three are PUBLIC client keys, safe to embed in the shipped app.
# Leave any unset to keep that provider OFF (telemetry is inert without keys).
#
# Sentry — errors/crashes. Get the DSN from your Sentry project settings.
VITE_SENTRY_DSN=
# PostHog — product analytics + feedback. Project API key (starts with phc_).
VITE_POSTHOG_KEY=
# PostHog host. EU recommended for the UK-company data residency.
#   EU: https://eu.i.posthog.com   US: https://us.i.posthog.com
VITE_POSTHOG_HOST=https://eu.i.posthog.com
# Optional: app version tag for Sentry releases (e.g. 0.1.0).
VITE_APP_VERSION=
